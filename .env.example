# Server
APP_NAME=ActionAPI
DEBUG=True
HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/action_api

# JWT
JWT_SECRET=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# NLP Provider (openai | local)
NLP_PROVIDER=local

# OpenAI (if NLP_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# Audio
AUDIO_ENABLED=false
